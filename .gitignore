# machine-local redline terms for scripts/redline-guard.py — never published
.redlines.local
__pycache__/

# graphify build output (generated; matches the convention in sibling repos)
graphify-out/

# graphify's generated git hooks. Unlike scripts/githooks/pre-commit (this
# repo's own redline guard, tracked on purpose), these are regenerated by
# `graphify hook install` and pin an absolute machine-local interpreter path,
# which the redline guard would reject anyway.
scripts/githooks/post-commit
scripts/githooks/post-checkout
